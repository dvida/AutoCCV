{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AutoCCV cv_data",
  "description": "Contract between the LLM extraction step (fills this from a PDF CV) and the deterministic generator. Keys are canonical section names matching data/section_map.json. Controlled-vocab values are HUMAN LABELS (the resolver maps them to CCV lov/refTable ids). Dates: yyyy/MM (YearMonth), yyyy (Year), yyyy-MM-dd (Date), MM/dd (MonthDay). null or \"\" => field omitted on export (always valid).",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "lang": {"type": "string", "default": "en"},
        "source_pdf": {"type": "string"},
        "seed_export": {"type": "string", "description": "path to the user's CCV export (REQUIRED at build time)"}
      }
    },
    "degrees": {"type": "array", "items": {"type": "object", "properties": {
      "degree_type": {"type": "string", "description": "Doctorate | Master's Thesis | Bachelor's"},
      "degree_name": {"type": "string"}, "specialization": {"type": "string"},
      "thesis_title": {"type": "string"}, "organization": {"type": "string"},
      "other_organization_type": {"type": "string"}, "degree_status": {"type": "string", "description": "Completed | In Progress"},
      "start": {"type": "string"}, "received": {"type": "string"}, "expected": {"type": "string"},
      "transferred_to_phd": {"type": "string", "description": "Yes | No"},
      "supervisors": {"type": "array", "items": {"type": "object", "properties": {
        "name": {"type": "string"}, "start": {"type": "string"}, "end": {"type": "string"}}}},
      "research_disciplines": {"type": "array", "items": {"type": "string"}},
      "areas_of_research": {"type": "array", "items": {"type": "string"}}
    }}},
    "academic_work_experience": {"type": "array", "items": {"type": "object", "properties": {
      "position_type": {"type": "string"}, "position": {"type": "string"},
      "organization": {"type": "string"}, "department": {"type": "string"},
      "start": {"type": "string"}, "end": {"type": "string"}, "description": {"type": "string"}}}},
    "nonacademic_work_experience": {"type": "array", "items": {"type": "object", "properties": {
      "position": {"type": "string"}, "position_status": {"type": "string"}, "organization": {"type": "string"},
      "start": {"type": "string"}, "end": {"type": "string"}, "description": {"type": "string"}}}},
    "research_funding": {"type": "array", "items": {"type": "object", "properties": {
      "funding_type": {"type": "string", "description": "Grant | Contract | Research Chair"},
      "funding_title": {"type": "string"}, "grant_type": {"type": "string"},
      "start": {"type": "string"}, "end": {"type": "string"},
      "role": {"type": "string", "description": "Principal Investigator | Co-investigator"},
      "status": {"type": "string", "description": "Awarded | Completed"},
      "clinical": {"type": "string"}, "description": {"type": "string"},
      "funding_sources": {"type": "array", "description": "MANDATORY: >=1 per grant, each with a funder (funding_organization OR other_funding_organization). The CCV portal will not submit a grant with no funding source.", "items": {"type": "object", "properties": {
        "funding_organization": {"type": "string", "description": "Funding agency as a catalog LOV label (data/lov_catalog.json 'Funding Organization'); if not a listed agency, leave blank and use other_funding_organization."},
        "other_funding_organization": {"type": "string", "description": "Free-text funder name when not a catalog agency."},
        "program_name": {"type": "string"},
        "total_funding": {"type": "number"},
        "currency_total": {"type": "string", "description": "Currency of Total Funding, e.g. CAD | USD"},
        "portion_received": {"type": "number", "description": "Portion of Funding Received by this researcher."},
        "competitive": {"type": "string", "description": "Funding Competitive? Yes | No"}}}}}}},
    "courses_taught": {"type": "array", "items": {"type": "object", "properties": {
      "role": {"type": "string"}, "organization": {"type": "string"}, "department": {"type": "string"},
      "session": {"type": "string", "description": "Fall | Winter | Spring | Summer"}, "session_year": {"type": "string"},
      "course_code": {"type": "string"}, "course_title": {"type": "string"},
      "level": {"type": "string", "description": "Undergraduate | Graduate"}, "num_students": {"type": "integer"}}}},
    "supervision": {"type": "array", "description": "Only supervisions with an end date in the last 6 years are imported (no end date => kept).", "items": {"type": "object",
      "required": ["degree_type", "student_name", "present_position", "start", "end"], "properties": {
      "role": {"type": "string", "description": "Principal Supervisor | Co-Supervisor"},
      "degree_type": {"type": "string", "description": "MANDATORY. Doctorate | Master's Thesis | Master's non-Thesis | Bachelor's Honours | Postdoctoral | ..."},
      "student_name": {"type": "string", "description": "MANDATORY"},
      "present_position": {"type": "string", "description": "MANDATORY. The student's current position."},
      "institution": {"type": "string"},
      "degree_name": {"type": "string"},
      "start": {"type": "string", "description": "MANDATORY (yyyy/MM)"}, "end": {"type": "string", "description": "MANDATORY (yyyy/MM)"},
      "thesis_title": {"type": "string"}}}},
    "committee_memberships": {"type": "array", "items": {"type": "object", "properties": {
      "role": {"type": "string"}, "committee_name": {"type": "string"},
      "other_organization": {"type": "string"}, "other_organization_type": {"type": "string"},
      "start": {"type": "string"}, "end": {"type": "string"}, "description": {"type": "string"}}}},
    "other_memberships": {"type": "array", "items": {"type": "object", "properties": {
      "role": {"type": "string"}, "other_organization": {"type": "string"},
      "start": {"type": "string"}, "end": {"type": "string"}, "description": {"type": "string"}}}},
    "recognitions": {"type": "array", "items": {"type": "object", "properties": {
      "recognition_type": {"type": "string", "description": "Honor | Prize / Award | Distinction | Citation"},
      "name": {"type": "string"}, "other_organization": {"type": "string"}, "other_organization_type": {"type": "string"},
      "effective_date": {"type": "string"}, "amount": {"type": "number"}, "currency": {"type": "string"},
      "description": {"type": "string"}}}},
    "editorial_activities": {"type": "array", "items": {"type": "object", "properties": {
      "role": {"type": "string"}, "publication_type": {"type": "string"}, "publication_name": {"type": "string"},
      "start": {"type": "string"}, "end": {"type": "string"}, "description": {"type": "string"}}}},
    "journal_reviews": {"type": "array", "items": {"type": "object", "properties": {
      "role": {"type": "string", "default": "Reviewer"}, "journal": {"type": "string"}}}},
    "credentials": {"type": "array", "items": {"type": "object", "properties": {
      "title": {"type": "string"}, "other_organization": {"type": "string"}, "other_organization_type": {"type": "string"},
      "effective_date": {"type": "string"}, "description": {"type": "string"}}}},
    "presentations": {"type": "array", "items": {"type": "object", "properties": {
      "title": {"type": "string"}, "event": {"type": "string"}, "city": {"type": "string"},
      "invited": {"type": "string", "description": "Yes | No"}, "year": {"type": "string"}}}},
    "journal_articles": {"type": "array", "items": {"type": "object", "properties": {
      "title": {"type": "string"}, "journal": {"type": "string"}, "volume": {"type": "string"},
      "issue": {"type": "string"}, "pages": {"type": "string"}, "year": {"type": "string"},
      "status": {"type": "string", "description": "MANDATORY. Published | Accepted | In Press | Submitted | Revision Requested (in-review papers => Submitted; an article with no resolvable status is dropped and flagged)"},
      "refereed": {"type": "string", "description": "Yes | No"}, "authors": {"type": "string"},
      "doi": {"type": "string"}, "contribution": {"type": "string", "description": "0-10 | 11-20 | 21-30 | 31-40"}}}},
    "conference_publications": {"type": "array", "items": {"type": "object",
      "required": ["title", "publication_type", "conference", "status", "year", "refereed", "invited", "authors"], "properties": {
      "title": {"type": "string"},
      "publication_type": {"type": "string", "description": "MANDATORY. Abstract | Paper | Poster"},
      "conference": {"type": "string", "description": "MANDATORY. Conference name"}, "city": {"type": "string"},
      "published_in": {"type": "string"}, "pages": {"type": "string"},
      "year": {"type": "string", "description": "MANDATORY"},
      "status": {"type": "string", "description": "MANDATORY. Accepted | In Press | Published | Revision Requested | Submitted"},
      "refereed": {"type": "string", "description": "MANDATORY. Yes | No"},
      "invited": {"type": "string", "description": "MANDATORY. Yes | No"},
      "authors": {"type": "string", "description": "MANDATORY"}, "doi": {"type": "string"}}}},
    "reports": {"type": "array", "description": "Only reports submitted in the last 6 years are imported.", "items": {"type": "object",
      "required": ["title", "year", "authors"], "properties": {
      "title": {"type": "string"}, "other_organization": {"type": "string"},
      "other_organization_type": {"type": "string", "description": "MANDATORY when other_organization is set. Academic | Federal Government | Not for Profit | Private Sector | Provincial Government | Research"},
      "num_pages": {"type": "number", "description": "Number of Pages (defaults to 1 if omitted)"},
      "year": {"type": "string", "description": "MANDATORY. Year Submitted"},
      "authors": {"type": "string", "description": "MANDATORY"}}}},
    "books": {"type": "array", "items": {"type": "object"}},
    "book_chapters": {"type": "array", "items": {"type": "object"}},
    "text_interviews": {"type": "array", "items": {"type": "object",
      "required": ["topic", "forum", "date"], "properties": {
      "topic": {"type": "string", "description": "MANDATORY"}, "interviewer": {"type": "string"},
      "forum": {"type": "string", "description": "MANDATORY"},
      "date": {"type": "string", "description": "MANDATORY. Publication date (yyyy-MM-dd)"}, "url": {"type": "string"}}}},
    "broadcast_interviews": {"type": "array", "items": {"type": "object", "properties": {
      "topic": {"type": "string"}, "interviewer": {"type": "string"}, "program": {"type": "string"},
      "network": {"type": "string"}, "date": {"type": "string"}, "url": {"type": "string"}}}},
    "ktt": {"type": "array", "items": {"type": "object", "properties": {
      "role": {"type": "string"}, "activity_type": {"type": "string"}, "target_stakeholder": {"type": "string"},
      "outcome": {"type": "string"}, "url": {"type": "string"}, "description": {"type": "string"}}}},
    "international_collaboration": {"type": "array", "items": {"type": "object", "properties": {
      "role": {"type": "string"}, "location": {"type": "string", "description": "country name"},
      "start": {"type": "string"}, "end": {"type": "string"}, "description": {"type": "string"}}}},
    "event_administration": {"type": "array", "items": {"type": "object", "properties": {
      "role": {"type": "string"}, "event_type": {"type": "string", "description": "Conference | Workshop | ..."},
      "event_name": {"type": "string"}, "start": {"type": "string"}, "end": {"type": "string"},
      "event_start": {"type": "string"}, "event_end": {"type": "string"}}}},
    "organizational_review": {"type": "array", "items": {"type": "object", "properties": {
      "role": {"type": "string"}, "organization": {"type": "string"}, "other_organization_type": {"type": "string"},
      "start": {"type": "string"}, "end": {"type": "string"}, "description": {"type": "string"}}}},
    "leaves_of_absence": {"type": "array", "items": {"type": "object", "properties": {
      "leave_type": {"type": "string"}, "organization": {"type": "string"},
      "start": {"type": "string"}, "end": {"type": "string"}, "description": {"type": "string"}}}},
    "affiliations": {"type": "array", "items": {"type": "object", "properties": {
      "position": {"type": "string"}, "organization": {"type": "string"}, "other_organization_type": {"type": "string"},
      "department": {"type": "string"}, "description": {"type": "string"},
      "start": {"type": "string"}, "end": {"type": "string"}}}},
    "working_papers": {"type": "array", "items": {"type": "object", "properties": {
      "title": {"type": "string"}, "authors": {"type": "string"}, "url": {"type": "string"}}}},
    "user_profile": {"type": "array", "description": "MANDATORY. Single object in a one-element array. The CCV portal requires the User Profile section with >=1 Research Specialization Keyword to submit.", "items": {"type": "object",
      "required": ["research_keywords"], "properties": {
      "research_keywords": {"type": "array", "description": "MANDATORY: >=1 keyword. If the CV lists no explicit keywords, ask the user (suggest some derived from research areas/disciplines) rather than fabricating.", "items": {"type": "string"}}}}}
  }
}
